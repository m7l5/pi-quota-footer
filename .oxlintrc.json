{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "jsdoc",
    "promise",
    "node",
    "react",
    "react-perf",
    "jsx-a11y",
    "jest",
    "vitest",
    "nextjs"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "style": "off",
    "perf": "warn",
    "restriction": "off",
    "nursery": "off"
  },
  "env": {
    "builtin": true,
    "node": true,
    "browser": false,
    "es2022": true
  },
  "ignorePatterns": ["node_modules/**"],
  "rules": {
    "typescript/no-explicit-any": "error",
    "jsdoc/require-param": "off",
    "jsdoc/require-returns": "off",
    "max-lines": "off",
    "max-lines-per-function": "off",
    "max-params": "off",
    "unicorn/no-useless-undefined": "off"
  }
}
